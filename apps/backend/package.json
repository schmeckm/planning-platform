{
  "name": "@PCP/backend",
  "version": "0.1.0",
  "description": "Pharma Collective Platform – REST API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "tsx scripts/db-seed.ts"
  },
  "dependencies": {
    "@PCP/planning-core": "workspace:*",
    "@PCP/planning-constraints": "workspace:*",
    "@PCP/planning-pharma": "workspace:*",
    "@PCP/planning-cgt": "workspace:*",
    "@PCP/planning-adapters": "workspace:*",
    "@PCP/planning-shopfloor": "workspace:*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "jsonwebtoken": "^9.0.2",
    "http-proxy-middleware": "^3.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0"
  }
}
