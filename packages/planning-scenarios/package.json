{
  "name": "@PCP/planning-scenarios",
  "version": "0.1.0",
  "description": "Pharma Collective Platform – demo scenarios and fixtures (scaffold)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm -r --filter \"@PCP/planning-scenarios...\" build",
    "test": "vitest run",
    "lint": "eslint src --config ../../eslint.config.mjs"
  },
  "dependencies": {
    "@PCP/planning-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
