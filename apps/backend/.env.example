# OPP backend — copy to .env for local development
PORT=3100

# OPP shadow database (pcp_* tables) — required for persistence across restarts
# Host port 5433 avoids conflict with other Postgres on 5432 (see docker-compose.yml)
PCP_DATABASE_URL=postgresql://opp:opp_dev_password@127.0.0.1:5433/opp

# HAE production data (hap_* tables, read-only adapter) — matches HAE root .env local dev
ALLOCATION_DATABASE_URL=postgresql://hap:hap-local-dev@127.0.0.1:5432/hap

# SAP S/4HANA OData (live mode when SAP_BASE_URL is set; otherwise fixture demo data)
# SAP_BASE_URL=https://your-system.s4hana.ondemand.com
# SAP_CLIENT=100
# SAP_USERNAME=
# SAP_PASSWORD=
# SAP_PLANT=1000
# SAP_ADAPTER_MODE=fixture

# ERPNext REST API (fixture mode when ERPNEXT_BASE_URL unset)
# ERPNEXT_BASE_URL=https://erp.example.com
# ERPNEXT_API_KEY=
# ERPNEXT_API_SECRET=
# ERPNEXT_COMPANY=Pharma Collective GmbH
# ERPNEXT_ADAPTER_MODE=fixture
