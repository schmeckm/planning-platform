# OPP backend — copy to .env for local development
PORT=3100

# OPP shadow database (pcp_* tables) — required for persistence across restarts
PCP_DATABASE_URL=postgresql://opp:opp_dev_password@localhost:5432/opp

# HAE production data (hap_* tables, read-only adapter) — optional
# ALLOCATION_DATABASE_URL=postgresql://hap:change-me@localhost:5432/hap

# SAP S/4HANA OData (live mode when SAP_BASE_URL is set; otherwise fixture demo data)
# SAP_BASE_URL=https://your-system.s4hana.ondemand.com
# SAP_CLIENT=100
# SAP_USERNAME=
# SAP_PASSWORD=
# SAP_PLANT=1000
# SAP_ADAPTER_MODE=fixture
