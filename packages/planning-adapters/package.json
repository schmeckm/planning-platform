{
  "name": "@PCP/planning-adapters",
  "version": "0.1.0",
  "description": "Pharma Collective Platform – ERP/MES/LIMS adapter layer",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm -r --filter \"@PCP/planning-adapters...\" build",
    "test": "vitest run",
    "verify:sap": "tsx src/scripts/verify-sap-connection.ts"
  },
  "dependencies": {
    "@PCP/planning-core": "workspace:*",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0"
  }
}
